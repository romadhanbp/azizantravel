---
import Base from '../../../layouts/Base.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const blogPosts = (await getCollection('blog-en'))
  .filter(p => p.data.published)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Blog - Lombok Travel Tips & Guides" description="Read the latest articles, tips, and Lombok travel guides. Travel inspiration from Azizan Travel." activePage="blog" lang="en">

  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/en">Home</a>
        <span>/</span>
        <span>Blog</span>
      </div>
      <span class="section-tag">Blog & Tips</span>
      <h1 class="section-title">Lombok Travel Inspiration</h1>
      <p>Tips, guides, and exciting stories about Lombok tourism for your journey.</p>
    </div>
  </section>

  <section class="blog-section" style="padding: 60px 0 80px;">
    <div class="container">
      <div class="blog-grid" id="blogListGrid">
        {blogPosts.map(p => (
          <BlogCard
            title={p.data.title}
            slug={p.data.slug}
            category={p.data.category}
            date={p.data.date}
            image={p.data.image}
            excerpt={p.data.excerpt}
            tags={p.data.tags}
            lang="en"
          />
        ))}
      </div>
    </div>
  </section>

</Base>
