---
import Base from '../layouts/Base.astro';
import { CONFIG } from '../data/config';
import { SEO } from '../data/seo';
---

<Base title="Kontak & Lokasi - Azizan Travel Lombok" description="Hubungi Azizan Travel via WhatsApp, telepon, atau email. Kami siap melayani paket wisata Lombok, airport transfer, dan sewa kendaraan." activePage="kontak">

  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Beranda</a>
        <span>/</span>
        <span>Kontak</span>
      </div>
      <span class="section-tag">Hubungi Kami</span>
      <h1 class="section-title">Dapatkan Informasi Lengkap</h1>
      <p>Kami siap merespon pertanyaan Anda dalam hitungan menit via WhatsApp</p>
    </div>
  </section>

  <section class="contact-section" style="padding:60px 0 80px;">
    <div class="container">
      <div class="contact-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:40px;">

        <div class="contact-info-column">
          <div class="contact-card" style="background:var(--white);border-radius:var(--radius-lg);padding:32px;border:1px solid var(--cream-dark);margin-bottom:24px;">
            <div class="cc-icon" style="font-size:2rem;margin-bottom:16px;">📍</div>
            <h3 style="font-family:var(--font-heading);font-size:1.1rem;font-weight:600;color:var(--dark);margin-bottom:8px;">Alamat</h3>
            <p style="color:var(--gray);line-height:1.7;">{CONFIG.address}<br />Nusa Tenggara Barat</p>
          </div>

          <div class="contact-card" style="background:var(--white);border-radius:var(--radius-lg);padding:32px;border:1px solid var(--cream-dark);margin-bottom:24px;">
            <div class="cc-icon" style="font-size:2rem;margin-bottom:16px;">📱</div>
            <h3 style="font-family:var(--font-heading);font-size:1.1rem;font-weight:600;color:var(--dark);margin-bottom:8px;">WhatsApp / Telepon</h3>
            <p style="color:var(--gray);line-height:1.7;">
              <a href={`https://wa.me/${CONFIG.waNumber}?utm_source=website`} style="color:var(--primary);font-weight:600;text-decoration:none;">+62 819-9986-8882</a>
            </p>
            <p style="color:var(--gray);font-size:0.85rem;">Respons cepat dalam hitungan menit</p>
          </div>

          <div class="contact-card" style="background:var(--white);border-radius:var(--radius-lg);padding:32px;border:1px solid var(--cream-dark);margin-bottom:24px;">
            <div class="cc-icon" style="font-size:2rem;margin-bottom:16px;">📧</div>
            <h3 style="font-family:var(--font-heading);font-size:1.1rem;font-weight:600;color:var(--dark);margin-bottom:8px;">Email</h3>
            <p style="color:var(--gray);line-height:1.7;">
              <a href={`mailto:${CONFIG.email}`} style="color:var(--primary);font-weight:600;text-decoration:none;">{CONFIG.email}</a>
            </p>
          </div>

          <div class="contact-card" style="background:var(--white);border-radius:var(--radius-lg);padding:32px;border:1px solid var(--cream-dark);">
            <div class="cc-icon" style="font-size:2rem;margin-bottom:16px;">🕐</div>
            <h3 style="font-family:var(--font-heading);font-size:1.1rem;font-weight:600;color:var(--dark);margin-bottom:8px;">Jam Operasional</h3>
            <p style="color:var(--gray);line-height:1.7;">Senin - Minggu: 06.00 - 22.00 WITA<br />24 jam untuk airport transfer & darurat</p>
          </div>
        </div>

        <div>
          <div class="contact-form-card" style="background:var(--white);border-radius:var(--radius-lg);padding:40px;border:1px solid var(--cream-dark);">
            <h3 style="font-family:var(--font-heading);font-size:1.3rem;font-weight:700;color:var(--dark);margin-bottom:8px;">✉️ Kirim Pesan</h3>
            <p style="color:var(--gray);margin-bottom:28px;">Isi form di bawah dan kami akan merespon via WhatsApp</p>

            <form id="bookingForm">
              <div class="form-group">
                <label for="namaInput">Nama Lengkap *</label>
                <input type="text" id="namaInput" placeholder="Masukkan nama lengkap Anda" required />
              </div>
              <div class="form-group">
                <label for="hpInput">No. WhatsApp *</label>
                <input type="tel" id="hpInput" placeholder="08xxxxxxxxxx" required />
              </div>
              <div class="form-group">
                <label for="paketSelect">Layanan yang Diinginkan *</label>
                <select id="paketSelect" required>
                  <option value="">-- Pilih Layanan --</option>
                  <option>Paket Wisata Lombok</option>
                  <option>Sewa Kendaraan + Driver</option>
                  <option>Airport Transfer BIL</option>
                  <option>Trekking Gunung Rinjani</option>
                  <option>Konsultasi Paket Custom</option>
                  <option>Lainnya</option>
                </select>
              </div>
              <div class="form-group">
                <label for="tanggalInput">Tanggal Perjalanan (opsional)</label>
                <input type="date" id="tanggalInput" />
              </div>
              <div class="form-group">
                <label for="pesanInput">Pesan / Pertanyaan</label>
                <textarea id="pesanInput" rows="4" placeholder="Ceritakan kebutuhan Anda..."></textarea>
              </div>
              <button type="submit" class="btn btn-wa" style="width:100%;justify-content:center;">
                💬 Kirim via WhatsApp
              </button>
            </form>
          </div>
        </div>

      </div>

      <div class="contact-map" style="margin-top:48px;">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3945.456789!2d116.2681!3d-8.6588!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd1f2b123456789%3A0x1234567890abcdef!2sJl.%20H%20Muhammad%20Umar%2C%20Telagawaru%2C%20Praya%2C%20Lombok%20Tengah!5e0!3m2!1sid!2sid!4v1"
          width="100%" height="400" style="border:0;border-radius:var(--radius-lg);" allowfullscreen="" loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </section>

</Base>
