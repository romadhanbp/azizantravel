---
import Base from '../layouts/Base.astro';
import PackageCard from '../components/PackageCard.astro';
import TransportCard from '../components/TransportCard.astro';
import BlogCard from '../components/BlogCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { getCollection } from 'astro:content';

const packages = (await getCollection('packages'))
  .filter(p => p.data.featured && p.data.category !== 'custom')
  .sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const transport = (await getCollection('transport'))
  .sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const homepageSections = await getCollection('homepage');
const getSection = (name) => homepageSections.find(s => s.data.section === name)?.data || {};

const hero = getSection('hero');
const whyUs = getSection('why-us');
const cta = getSection('cta');
const gallery = getSection('gallery');
const transportHeader = getSection('transport-header');
const packagesHeader = getSection('packages-header');
const blogHeader = getSection('blog-header');

const testimonials = (await getCollection('testimonials'))
  .sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
---

<Base title="Azizan Travel - Paket Wisata & Transportasi Lombok Terpercaya" description="Azizan Travel melayani paket wisata Lombok, transportasi airport, sewa kendaraan, dan keperluan perjalanan selama di Lombok. Profesional, nyaman, harga terjangkau." activePage="index">

  <!-- ====== HERO ====== -->
  <section class="hero" id="beranda">
    <div class="hero-bg"></div>
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">
          <span>{hero.badgeIcon}</span> {hero.badge}
        </div>
        <h1 class="hero-title">
          Jelajahi <span class="highlight">{hero.highlightWord}</span><br />
          Lombok Bersama Kami
        </h1>
        <p class="hero-desc">
          {hero.description}
        </p>
        <div class="hero-actions">
          <a href={hero.buttonPrimaryLink} class="btn btn-primary">{hero.buttonPrimary}</a>
          <a href={hero.buttonSecondaryLink} class="btn btn-white" id="heroBooking">{hero.buttonSecondary}</a>
        </div>
        <div class="hero-stats">
          {hero.stats?.map(stat => (
            <div class="stat-item">
              <div class="stat-number">{stat.number}</div>
              <div class="stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
    <div class="hero-scroll">
      <span class="scroll-text">Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ====== WHY CHOOSE US ====== -->
  <section class="why-us" id="tentang">
    <div class="container">
      <div class="why-grid">
        <div class="why-image reveal">
          <img src={whyUs.image} alt="Azizan Travel Lombok" loading="lazy" />
          <div class="why-badge">
            <div class="why-badge-icon">{whyUs.badgeIcon}</div>
            <div class="why-badge-text">
              <div class="number">{whyUs.badgeNumber}</div>
              <small>{whyUs.badgeText}</small>
            </div>
          </div>
        </div>
        <div class="why-text reveal">
          <span class="section-tag">{whyUs.tag}</span>
          <h2 class="section-title">{whyUs.title}</h2>
          <p class="section-subtitle">
            {whyUs.description}
          </p>
          <div class="why-features">
            {whyUs.features?.map(feature => (
              <div class="feature-item">
                <div class="feature-icon">{feature.icon}</div>
                <div class="feature-text">
                  <h4>{feature.title}</h4>
                  <p>{feature.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== TRANSPORT ====== -->
  <section class="transport" id="transport">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag">{transportHeader.tag}</span>
        <h2 class="section-title">{transportHeader.title}</h2>
        <p class="section-subtitle">{transportHeader.description}</p>
      </div>
      <div class="transport-grid">
        {transport.map(a => (
          <TransportCard
            title={a.data.title}
            slug={a.data.slug}
            image={a.data.image}
            badge={a.data.badge}
            category={a.data.category}
            capacity={a.data.capacity}
            luggage={a.data.luggage}
            price={a.data.price}
            pricePer={a.data.pricePer}
            includes={a.data.includes}
            description={a.data.description}
          />
        ))}
      </div>
      <div class="text-center" style="margin-top: 40px;">
        <a href="/transportasi" class="btn btn-outline">Lihat Semua Transportasi →</a>
      </div>
    </div>
  </section>

  <!-- ====== PACKAGES ====== -->
  <section class="packages" id="paket">
    <div class="container">
      <div class="packages-header">
        <div>
          <span class="section-tag">{packagesHeader.tag}</span>
          <h2 class="section-title">{packagesHeader.title}</h2>
        </div>
      </div>
      <div class="packages-grid" id="packagesGrid">
        {packages.map(p => (
          <PackageCard
            title={p.data.title}
            slug={p.data.slug}
            category={p.data.category}
            image={p.data.image}
            badge={p.data.badge}
            duration={p.data.duration}
            maxGroup={p.data.maxGroup}
            price={p.data.price}
            pricePer={p.data.pricePer}
            includes={p.data.includes}
            description={p.data.description}
          />
        ))}
      </div>
      <div class="text-center" style="margin-top: 40px;">
        <a href="/paket" class="btn btn-outline">Lihat Semua Paket →</a>
      </div>
    </div>
  </section>

  <!-- ====== GALLERY ====== -->
  <section class="gallery" id="galeri">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag">{gallery.tag}</span>
        <h2 class="section-title">{gallery.title}</h2>
        <p class="section-subtitle">{gallery.description}</p>
      </div>
      <div class="gallery-grid">
        {gallery.items?.map(item => (
          <div class="gallery-item reveal">
            <img src={item.image} alt={item.label} loading="lazy" />
            <div class="gallery-overlay"><span class="gallery-label">{item.label}</span></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== TESTIMONIALS ====== -->
  <section class="testimonials" id="testimoni">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag">Testimoni</span>
        <h2 class="section-title">Kata Mereka Tentang Kami</h2>
      </div>
      <div class="testi-slider">
        {testimonials.map(t => (
          <TestimonialCard name={t.data.name} origin={t.data.origin} text={t.data.text} rating={t.data.rating} avatar={t.data.avatar} />
        ))}
      </div>
    </div>
  </section>

  <!-- ====== CTA BANNER ====== -->
  <section class="cta-banner" id="booking">
    <div class="container">
      <div class="cta-content">
        <div class="cta-text">
          <h2 class="section-title">{cta.title}</h2>
          <p>{cta.description}</p>
        </div>
        <div class="cta-actions">
          <a href={cta.buttonPrimaryLink} class="btn btn-white" id="openBookingModal">{cta.buttonPrimary}</a>
          <a href={cta.buttonSecondaryLink}
            class="btn btn-wa" target="_blank" rel="noopener">
            {cta.buttonSecondary}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== BLOG SECTION ====== -->
  <section class="blog" id="blog">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-tag">{blogHeader.tag}</span>
        <h2 class="section-title">{blogHeader.title}</h2>
        <p class="section-subtitle">{blogHeader.description}</p>
      </div>
      <div class="blog-grid" id="blogGrid">
        {blogPosts.map(p => (
          <BlogCard
            title={p.data.title}
            slug={p.data.slug}
            category={p.data.category}
            date={p.data.date}
            image={p.data.image}
            excerpt={p.data.excerpt}
            tags={p.data.tags}
            layout="home"
          />
        ))}
      </div>
      <div class="text-center" style="margin-top: 40px;">
        <a href="/blog" class="btn btn-outline">Lihat Semua Artikel →</a>
      </div>
    </div>
  </section>

</Base>
