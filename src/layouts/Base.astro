---
import { CONFIG } from '../data/config';
import { SEO } from '../data/seo';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

export interface Props {
  title: string;
  description: string;
  pageKey?: string;
  activePage?: string;
  ogImage?: string;
  navbarStyle?: 'transparent' | 'solid';
  lang?: 'id' | 'en';
}

const { title, description, pageKey = 'home', activePage = 'index', ogImage, navbarStyle = 'transparent', lang = 'id' } = Astro.props;
const pageUrl = SEO.site.url + Astro.url.pathname;
const ogImg = ogImage || SEO.site.defaultImage;

// Translations
const t = lang === 'en' ? {
  navHome: 'Home', navPackages: 'Packages', navTransport: 'Transport', navBlog: 'Blog', navContact: 'Contact', navBookNow: 'Book Now',
  footerDesc: 'Serving tourism, transportation, and your travel needs in Lombok with professionalism, comfort, and reliability since 2015.',
  footerServices: 'Our Services', footerNav: 'Navigation', footerContact: 'Contact Us',
  footerAddress: 'Address', footerWA: 'WhatsApp / Phone', footerEmail: 'Email',
  footerCopyright: 'All rights reserved.', footerMade: 'Made with ❤️ for Lombok travelers',
  formTitle: '📋 Booking Form', formName: 'Full Name *', formNamePH: 'Enter your full name',
  formWA: 'WhatsApp Number *', formWAPH: '08xxxxxxxxxx', formPeople: 'Number of People *', formPeoplePH: 'Number of participants',
  formPackage: 'Preferred Package *', formDate: 'Departure Date *', formPickup: 'Pickup Location', formPickupPH: 'Hotel / airport / address',
  formMessage: 'Message / Special Requests', formMessagePH: 'Example: baby, need extra seat, etc.',
  formSubmit: '💬 Send via WhatsApp',
  bottomHome: 'Home', bottomPackages: 'Packages', bottomBook: 'Book', bottomBlog: 'Blog', bottomContact: 'Contact',
} : {
  navHome: 'Beranda', navPackages: 'Paket', navTransport: 'Transportasi', navBlog: 'Blog', navContact: 'Kontak', navBookNow: 'Pesan Sekarang',
  footerDesc: 'Melayani wisata, transportasi, dan keperluan perjalanan Anda di Lombok dengan profesional, nyaman, dan terpercaya sejak 2015.',
  footerServices: 'Layanan Kami', footerNav: 'Navigasi', footerContact: 'Hubungi Kami',
  footerAddress: 'Alamat', footerWA: 'WhatsApp / Telepon', footerEmail: 'Email',
  footerCopyright: 'Hak cipta dilindungi undang-undang.', footerMade: 'Dibuat dengan ❤️ untuk wisatawan Lombok',
  formTitle: '📋 Form Pemesanan', formName: 'Nama Lengkap *', formNamePH: 'Masukkan nama lengkap Anda',
  formWA: 'No. WhatsApp *', formWAPH: '08xxxxxxxxxx', formPeople: 'Jumlah Orang *', formPeoplePH: 'Jumlah peserta',
  formPackage: 'Paket yang Diinginkan *', formDate: 'Tanggal Keberangkatan *', formPickup: 'Lokasi Penjemputan', formPickupPH: 'Hotel / bandara / alamat',
  formMessage: 'Pesan / Permintaan Khusus', formMessagePH: 'Contoh: ada bayi, butuh kursi tambahan, dll.',
  formSubmit: '💬 Kirim via WhatsApp',
  bottomHome: 'Beranda', bottomPackages: 'Paket', bottomBook: 'Pesan', bottomBlog: 'Blog', bottomContact: 'Kontak',
};

const prefix = lang === 'en' ? '/en' : '';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | {SEO.site.name}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:image" content={SEO.site.url + ogImg} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={SEO.site.url + ogImg} />
  <link rel="canonical" href={pageUrl} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧭</text></svg>" />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": SEO.organization.name,
    "description": SEO.organization.description,
    "url": SEO.organization.url,
    "telephone": SEO.organization.telephone,
    "email": SEO.organization.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": SEO.organization.address.street,
      "addressLocality": SEO.organization.address.city,
      "addressRegion": SEO.organization.address.region,
      "addressCountry": SEO.organization.address.country
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": SEO.organization.geo.latitude,
      "longitude": SEO.organization.geo.longitude
    },
    "sameAs": [
      SEO.social.instagram,
      SEO.social.facebook,
      SEO.social.tiktok,
      SEO.social.whatsapp
    ]
  })} />
</head>
<body>
  <!-- Skip to content link for accessibility -->
  <a href="#main-content" class="skip-link" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;z-index:9999;padding:12px 24px;background:var(--primary);color:white;font-weight:600;text-decoration:none;border-radius:0 0 var(--radius-sm) var(--radius-sm);" onfocus="this.style.left='50%';this.style.transform='translateX(-50%)'">Skip to content</a>

  <!-- ====== NAVBAR ====== -->
  <nav class:list={['navbar', { 'navbar-solid': navbarStyle === 'solid' }]} id="navbar">
    <div class="nav-container">
      <a href={`${prefix}/`} class="nav-logo">
        <div class="logo-icon">🧭</div>
        <div class="logo-text">
          <span class="logo-name">{SEO.site.name}</span>
          <span class="logo-tagline">{SEO.site.tagline}</span>
        </div>
      </a>
      <ul class="nav-menu" id="navMenu">
        <li><a href={`${prefix}/`} class="nav-link" class:list={{ active: activePage === 'index' }}>{t.navHome}</a></li>
        <li><a href={`${prefix}/paket`} class="nav-link" class:list={{ active: activePage === 'paket' }}>{t.navPackages}</a></li>
        <li><a href={`${prefix}/transportasi`} class="nav-link" class:list={{ active: activePage === 'transportasi' }}>{t.navTransport}</a></li>
        <li><a href={`${prefix}/blog`} class="nav-link" class:list={{ active: activePage === 'blog' }}>{t.navBlog}</a></li>
        <li><a href={`${prefix}/kontak`} class="nav-link" class:list={{ active: activePage === 'kontak' }}>{t.navContact}</a></li>
        <li><a href="#" class="nav-link nav-cta" id="navBooking">{t.navBookNow}</a></li>
      </ul>
      <LanguageSwitcher currentLang={lang} />
      <button class="nav-toggle" id="navToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Page Content -->
  <main id="main-content">
    <slot />
  </main>

  <!-- ====== FOOTER ====== -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="nav-logo">
            <div class="logo-icon">🧭</div>
            <div class="logo-text">
              <span class="logo-name">{SEO.site.name}</span>
              <span class="logo-tagline">{SEO.site.tagline}</span>
            </div>
          </div>
          <p class="footer-desc">
            {t.footerDesc}
          </p>
          <div class="footer-social">
            <a href={SEO.social.instagram} class="social-link" aria-label="Instagram" target="_blank" rel="noopener">📸</a>
            <a href={SEO.social.facebook} class="social-link" aria-label="Facebook" target="_blank" rel="noopener">👍</a>
            <a href={SEO.social.tiktok} class="social-link" aria-label="TikTok" target="_blank" rel="noopener">🎵</a>
            <a href={SEO.social.whatsapp + '?utm_source=website'} class="social-link" aria-label="WhatsApp" target="_blank" rel="noopener">💬</a>
          </div>
        </div>
        <div>
          <h4 class="footer-title">{t.footerServices}</h4>
          <ul class="footer-links">
            <li><a href={`${prefix}/paket`}>{lang === 'en' ? 'Lombok Tour Packages' : 'Paket Wisata Lombok'}</a></li>
            <li><a href={`${prefix}/transportasi`}>{lang === 'en' ? 'Car Rental' : 'Sewa Kendaraan'}</a></li>
            <li><a href={`${prefix}/transportasi`}>{lang === 'en' ? 'Airport Transfer' : 'Airport Transfer'}</a></li>
            <li><a href={`${prefix}/paket`}>{lang === 'en' ? 'Rinjani Trekking' : 'Trekking Rinjani'}</a></li>
            <li><a href={`${prefix}/paket`}>{lang === 'en' ? 'Gili Islands Tour' : 'Wisata Gili Islands'}</a></li>
            <li><a href={`${prefix}/paket`}>{lang === 'en' ? 'Honeymoon Package' : 'Paket Honeymoon'}</a></li>
          </ul>
        </div>
        <div>
          <h4 class="footer-title">{t.footerNav}</h4>
          <ul class="footer-links">
            <li><a href={`${prefix}/`}>{t.navHome}</a></li>
            <li><a href={`${prefix}/paket`}>{t.navPackages}</a></li>
            <li><a href={`${prefix}/transportasi`}>{t.navTransport}</a></li>
            <li><a href={`${prefix}/blog`}>{t.navBlog}</a></li>
            <li><a href={`${prefix}/kontak`}>{lang === 'en' ? 'Contact & Location' : 'Kontak & Lokasi'}</a></li>
            <li><a href="#" id="openBookingModal">{t.navBookNow}</a></li>
          </ul>
        </div>
        <div>
          <h4 class="footer-title">{t.footerContact}</h4>
          <div class="contact-item">
            <div class="contact-icon">📍</div>
            <div class="contact-info">
              <strong>{t.footerAddress}</strong>
              {CONFIG.address}<br />
              Nusa Tenggara Barat
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">📱</div>
            <div class="contact-info">
              <strong>{t.footerWA}</strong>
              <a href={`https://wa.me/${CONFIG.waNumber}?utm_source=website`}>+62 819-9986-8882</a>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">📧</div>
            <div class="contact-info">
              <strong>{t.footerEmail}</strong>
              <a href={`mailto:${CONFIG.email}`}>{CONFIG.email}</a>
            </div>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© <span id="copyrightYear"></span> {SEO.site.name}. {t.footerCopyright}</p>
        <p>{t.footerMade}</p>
      </div>
    </div>
  </footer>

  <!-- ====== BOOKING MODAL ====== -->
  <div class="modal-overlay" id="bookingModal">
    <div class="modal">
      <div class="modal-header">
        <h3 class="modal-title">{t.formTitle}</h3>
        <button class="modal-close" id="closeModal">✕</button>
      </div>
      <form id="bookingForm">
        <div class="form-group">
          <label for="namaInput">{t.formName}</label>
          <input type="text" id="namaInput" placeholder={t.formNamePH} required />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="hpInput">{t.formWA}</label>
            <input type="tel" id="hpInput" placeholder={t.formWAPH} required />
          </div>
          <div class="form-group">
            <label for="jumlahInput">{t.formPeople}</label>
            <input type="number" id="jumlahInput" min="1" placeholder={t.formPeoplePH} required />
          </div>
        </div>
        <div class="form-group">
          <label for="paketSelect">{t.formPackage}</label>
          <select id="paketSelect" required>
            <option value="">-- Pilih Paket --</option>
            <option value="Gili Trawangan Full Day">Gili Trawangan Full Day</option>
            <option value="Pink Beach & Tanjung Ringgit">Pink Beach & Tanjung Ringgit</option>
            <option value="Trekking Gunung Rinjani">Trekking Gunung Rinjani</option>
            <option value="Lombok Explorer 3D2N">Lombok Explorer 3D2N</option>
            <option value="Senggigi Sunset & Seafood Tour">Senggigi Sunset & Seafood Tour</option>
            <option value="Paket Honeymoon Lombok 4D3N">Paket Honeymoon Lombok 4D3N</option>
            <option value="Sewa Avanza/Calya">Sewa Avanza / Calya</option>
            <option value="Sewa Xenia">Sewa Xenia</option>
            <option value="Sewa Innova/Zenix">Sewa Innova / Zenix</option>
            <option value="Sewa Kendaraan + Driver Harian">Sewa Kendaraan + Driver Harian</option>
            <option value="Airport Transfer BIL">Airport Transfer BIL</option>
            <option value="Paket Custom">Paket Custom / Lainnya</option>
          </select>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="tanggalInput">{t.formDate}</label>
            <input type="date" id="tanggalInput" required />
          </div>
          <div class="form-group">
            <label for="penjemputanInput">{t.formPickup}</label>
            <input type="text" id="penjemputanInput" placeholder={t.formPickupPH} />
          </div>
        </div>
        <div class="form-group">
          <label for="pesanInput">{t.formMessage}</label>
          <textarea id="pesanInput" placeholder={t.formMessagePH}></textarea>
        </div>
        <button type="submit" class="btn btn-wa" style="width:100%; justify-content:center; font-size:1rem;">
          {t.formSubmit}
        </button>
      </form>
    </div>
  </div>

  <!-- ====== TO TOP BUTTON ====== -->
  <div class="to-top" id="toTop">
    <button class="to-top-btn" aria-label="Ke atas">⬆</button>
  </div>

  <!-- ====== WA FLOAT BUTTON ====== -->
  <div class="wa-float">
    <a href={`https://wa.me/${CONFIG.waNumber}?text=Halo%20${encodeURIComponent(SEO.site.name)}%2C%20saya%20ingin%20informasi%20lebih%20lanjut&utm_source=website`}
      class="wa-float-btn" target="_blank" rel="noopener" id="waFloatBtn" aria-label="WhatsApp Azizan Travel">
      <span class="wa-icon">💬</span>
      <span>Chat WhatsApp</span>
    </a>
  </div>

  <!-- ====== BOTTOM NAV (Mobile) ====== -->
  <nav class="bottom-nav" aria-label="Navigasi mobile">
    <div class="bottom-nav-inner">
      <a href={`${prefix}/`} class="bottom-nav-item" class:list={{ active: activePage === 'index' }}>
        <span class="bn-icon">🏠</span>
        <span class="bn-label">{t.bottomHome}</span>
      </a>
      <a href={`${prefix}/paket`} class="bottom-nav-item" class:list={{ active: activePage === 'paket' }}>
        <span class="bn-icon">🗺️</span>
        <span class="bn-label">{t.bottomPackages}</span>
      </a>
      <a href="#" class="bottom-nav-item bn-cta" id="bottomNavBooking">
        <span class="bn-icon">💬</span>
        <span class="bn-label">{t.bottomBook}</span>
      </a>
      <a href={`${prefix}/blog`} class="bottom-nav-item" class:list={{ active: activePage === 'blog' }}>
        <span class="bn-icon">📖</span>
        <span class="bn-label">{t.bottomBlog}</span>
      </a>
      <a href={`${prefix}/kontak`} class="bottom-nav-item" class:list={{ active: activePage === 'kontak' }}>
        <span class="bn-icon">📞</span>
        <span class="bn-label">{t.bottomContact}</span>
      </a>
    </div>
  </nav>

  <!-- Scripts -->
  <script>
    // === CONFIG ===
    const CONFIG = {
      waNumber: '{CONFIG.waNumber}',
      businessName: '{SEO.site.name}',
      address: `{CONFIG.address}`,
      email: '{CONFIG.email}'
    };
  </script>
  <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script is:inline>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
  <script is:inline src="/js/main.js"></script>
</body>
</html>
